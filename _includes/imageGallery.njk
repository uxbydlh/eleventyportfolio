{%- macro gallery(params) -%}

<div class="swipe-gallery {{params.imgLength}} 
            {%if params.images.length > 2%} multi-image {%endif%}
            {%if params.images.length === 2%} duo-image {%endif%}
            {%if params.images.length === 1%} single-image {%endif%}
            {{params.galleryId}} swipebox" >
    {% for image in params.images %}
        <a rel="{{params.galleryId}}" 
        href="{{image | toAbsoluteUrl}}" title="">
            <img src="{{image | toAbsoluteUrl}}">
        </a>
    {% endfor %}
</div>

{%- endmacro -%}