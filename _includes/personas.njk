{%- macro personas(params) -%}

<ul class="card-list personas">
    {% for persona in params.personas %}
        <li class="table-card">
            <div class="table-card-header">
                <div>
                    <i class="{{persona.icon}}"></i>
                    <h4>{{persona.name}}</h4>
                </div>
                <p>{{persona.subheading}}</p>
            </div>
            <div class="table-card-body">
                {% if persona.age and persona.location and persona.profession %}
                    <h4>Info</h4>
                    <ul>
                        <li>
                            {{persona.age}}
                        </li>
                        <li>
                            {{persona.location}}
                        </li>
                        <li>
                            {{persona.profession}}
                        </li>
                    </ul>
                {% endif %}
                {% if persona.goals %}
                    <h4>Goals</h4>
                    {% for goal in persona.goals %}
                        <ul>
                            <li>{{goal}}</li>
                        </ul>
                    {% endfor %}
                {% endif %}
                {% if persona.barriers %}
                    <h4>Barriers</h4>
                    {% for barrier in persona.barriers %}
                        <ul>
                            <li>{{barrier}}</li>
                        </ul>
                    {% endfor %}
                {% endif %}
                {% if persona.quote %}
                    <q>{{persona.quote}}</q>
                {% endif %}
            </div>
        </li>
    {% endfor %}
</ul>

{%- endmacro -%}