---
layout: layouts/base.njk
---
{# Only include the syntax highlighter CSS on blog posts, included with the CSS per-page bundle #}
<style>{% include "node_modules/prismjs/themes/prism-okaidia.css" %}</style>
<style>{% include "css/prism-diff.css" %}</style>

<h1>{{ title }}</h1>

<div class="article-container">
    <aside>
        {% if eleventyNavigation.parent %}
            <a href="{{eleventyNavigation.parentUrl | toAbsoluteUrl }}" class="btn primary"><i></i>Back to {{eleventyNavigation.parent}}</a>
        {% endif %}
        <h3>Contents</h3>
        {{ content | toc | safe }}
    </aside>
    <div class="content">
        {{content | safe }}
    </div>
</div>

<div class="meta-container">
    {%- if collections.projects %}
            {%- set previousPost = collections.projects | getPreviousCollectionItem %}
            {%- set nextPost = collections.projects | getNextCollectionItem %}
            {%- if nextPost or previousPost %}
            <ul class="links-nextprev">
                {%- if previousPost %}
                <a href="{{ previousPost.url }}">
                    <li class="card links-nextprev-prev">
                        <i class="ri-arrow-left-s-fill"></i>
                        <div>
                            <h4>Previous</h4>
                            <h5>{{ previousPost.data.title }}</h5>
                        </div>
                    </li>{% endif %}
                </a>
                {%- if nextPost %}
                <a href="{{ nextPost.url }}">
                    <li class="card links-nextprev-next">
                        <div>
                            <h4>Next</h4>
                            <h5>
                                {{ nextPost.data.title }}
                            </h5>
                        </div>
                        <i class="ri-arrow-right-s-fill"></i>
                    </li>
                </a>
                
                {% endif %}
            </ul>
        {%- endif %}
    {%- endif %}
</div>

{#TODO ADD AN ICON TO THIS#}
{#TODO ADD PROPER STYLING TO THIS SO IT LOOKS MORE LIKE A BUTTON#}
<div class="scroll-top"> <!--scrollbar at the end of the main-->
	<a class="scroll-top__link" href="#">Back to top</a> <!--href="#" navigate to the top of the page-->
</div> 

{#TODO GIVE THE METADATA SOME PROPER STYLE#}
<ul class="post-metadata">
				<li><time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time></li>
				{%- for tag in tags | filterTagList %}
				{%- set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
				<li><a href="{{ tagUrl }}" class="post-tag">{{ tag }}</a>{%- if not loop.last %}, {% endif %}</li>
				{%- endfor %}
			</ul>

<script>

	var potentialDropdowns = document.querySelectorAll("nav.toc ol li");
    var potentialDropdownsCopy = Array.from(potentialDropdowns);

    function hasChildren(obj, index, arr) {
        return obj.children.length > 1;
    }

	var listsWithKids = potentialDropdownsCopy.filter(hasChildren);
    console.log(listsWithKids);

    listsWithKids.forEach(element => {
        element.classList.add("contentParent");
        element.classList.add("closed");

        //wrap "opener link" in a summary parent tag
        let linkChild = element.firstChild;
        $(linkChild).wrap('<div class="toc_nav_link"></div>');
        $('<i class="ri-arrow-down-s-fill"></i>').insertBefore(linkChild);

        //provide function to the parent tag
        linkChild.parentNode.addEventListener("click", function() {
            element.classList.toggle("closed");
        });
    });

    ;(function($) {
         $('.swipebox').swipebox();
      }) (jQuery);
</script>
