{%- macro latestProjects(params) -%}
    <ul class="card-list">
		{% set latest_projects = params.projectList | reverse %}
		{% for item in latest_projects.slice(0,3) %}
		<a href="{{item.url | toAbsoluteUrl }}">
			<li class="card">
				<img class="card-photo" src="{{item.data.bannerImg | toAbsoluteUrl}}">
				<h4>{{item.data.title}}</h4>
				{% if item.templateContent %}
					{% set safeExcerpt = item.templateContent | striptags | truncate(140, false, "...") %}
					<p>{{safeExcerpt}}</p>
					<meta name="description" content = "{{ safeExcerpt }}">
					<meta property="og:description" content="{{ safeExcerpt }}">
				{% endif%}
			</li>
		</a>
		{% endfor %}
	</ul>
{%- endmacro -%}
