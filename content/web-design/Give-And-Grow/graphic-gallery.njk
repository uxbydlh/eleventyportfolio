						"assets/images/case-studies/Give-and-Grow/Gallery/illustrations/tutorgains.webp",
						"assets/images/case-studies/Give-and-Grow/Gallery/illustrations/tutorqual.webp",
						"assets/images/case-studies/Give-and-Grow/Gallery/illustrations/tutorrespons.webp"
					]
				})
	}}
</div>

<h2>Model Illustration</h2>
<div class="article-section">
	{{ carousel({ carouselId: "modelCarousel",
					images: [
						"assets/images/case-studies/Give-and-Grow/Gallery/illustrations/fundingmodel.webp"
						],
					orientation: "slides-horiz",
					plurality: "single-image"
				}) 
	}}
</div>