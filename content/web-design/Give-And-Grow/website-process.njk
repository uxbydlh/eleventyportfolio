---js
const layout = "layouts/post.njk";

const eleventyNavigation = {
	key: "Website",
	parent: "Give & Grow",
	parentUrl: "/web-design/give-and-grow"
};

const tags = ["project","give-grow","web-design","dev"];

const date = "2025-06-06";

const title = "Give and Grow CIC";
const subheading = "Creating a functional website from the ground up for a tutoring CIC based in London";
const bannerImg = "assets/images/case-studies/Give-and-Grow/GAGBanner.webp";
---
{%- from 'inlineTable.njk' import inlineTable %}
{%- from 'imageGallery.njk' import gallery %}
{%- from 'alpineCarousel.njk' import alpineCarousel %}
{%- from 'personas.njk' import personas %}
{%- from 'filteredTestimonials.njk' import filteredTestimonials %}

<img class="banner-image" src='{{bannerImg | toAbsoluteUrl}}'>
<div class="article-section">
	Give and Grow is a community interest company dedicated to helping students who are unable to afford full-price tutoring sessions, but are also ineligible for financial support from traditional aid systems.
	<div class="btn row">
		<a class="btn primary"
					href="https://giveandgrowcic.co.uk/"
					target="_blank" rel="noopener noreferrer">Visit Give & Grow<i class="ri-arrow-right-s-fill"></i></a>
	</div>
</div>

<h2 id="details">Details</h2>
	{{ inlineTable ({
			table: [
				{
					header: "Scope",
					bodyItems: [
						"Founding volunteer",
						"Creator of design system and branding",
						"Full-site development from scratch"
					]
				},
				{
					header: "Role",
					bodyItems: [
						"Research",
						"UX & UI design",
						"Copywriting",
						"Graphic Design",
						"Web Development"
					]
