	}}

<h2 id="impact">Impact</h2>
<h3 id="completed-screens">Completed Screens</h3>
<div class="article-section">
	{{ alpineCarousel({ carouselId: "completedCarousel",
					images: [
						{src:"assets/images/case-studies/Give-and-Grow/Completed/homepage.webp"},
						{src:"assets/images/case-studies/Give-and-Grow/Completed/about.webp"},
						{src:"assets/images/case-studies/Give-and-Grow/Completed/meet-the-team.webp"},
