---js
const layout = "layouts/homepage.njk";

const numberOfLatestPostsToShow = 3;
const latestNewsToShow = 4;

const title = 'Dorian H.';

const logos = [
	{
		file: "logo-adenydd.png",
		link: "web-design/Adenydd",
		org: "Adenydd"
	},
	{
		file: "logo-DHH.png",
		link: "web-design/DHH",
		org: "Devon Healing Horsemanship"
	},
	{
		file: "logo-dotdot.svg",
		link: "case-studies/Morses-Club/DDL",
		org: "Dot Dot Loans"
	},
	{
		file: "logo-EcoCentre.png",
		link: "case-studies/E-Save",
		org: "Eco Centre Southwest"
	},
	{
		file: "logo-GiveGrow.svg",
		link: "web-design/give-and-grow",
		org: "Give and Grow: Community Powered Education"
	},
	{
		file: "logo-morses.svg",
		link: "case-studies/Morses-Club",
		org: "Morses Club PLC"
	},
	{
		file: "logo-ncr.svg",
		link: "about/#ncr-atleos",
		org: "NCR Atleos"
	},
	{
		file: "logo-oakbrook.svg",
		link: "about/#oakbrook-finance-limited",
		org: "Oakbrook Finance Limited"
	},
	{
		file: "logo-VED.webp",
		link: "web-design/VED",
		org: "Very Evil Demons"
	}
];

---
{%- from 'projectCards.njk' import latestProjects %}

<section class="centre" id="Model">
	<h2>Companies I've worked with</h2>
	<div class="marquee-wrapper">
		<div class="marquee-track">
			 <div class="dynamic-logo-list">
				<div class="marquee-list dynamic-items" role="list">
					{% for i in range(0, 2)%}
						{% for logo in logos %}
							<div class="marquee-item dynamic-item" role="listitem">
								<div class="marquee-image">
									<a href="{{logo.link}}">
										<img class="image" src="{{'../assets/images/3rd-party-logos/' + logo.file}}" loading="lazy" alt="{{logo.org}}">
									</a>
								</div>
							</div>
						{% endfor %}
					{% endfor %}
				</div>
			 </div>
		</div>
	</div>
	<div class="btn-row-inline">
		<a class="btn primary" href="about/#tools-and-skills">View CV<i class="ri-arrow-right-s-fill"></i></a>
	</div>
</section>

<section class="centre" id="LatestProj">
	<h2>Latest Projects</h2>
	{{ latestProjects ({ projectList: collections.projects }) }}
	<a class="btn primary" href="/projects">View All Projects<i class="ri-arrow-right-s-fill"></i></a>
</section>

<section class="centre" id="FeaturedTest">
	<h2>Featured Testimonials</h2>
	{% set testList = testimonials | shuffle %}
	<ul class="card-list">
		{% for testimonial in testList.slice(0,3) %}
		<li class="card testimonial">
			<q>{{testimonial.testimonial}}</q>
			<div class="persona"><i class="ri-chat-2-fill"></i><p><b>{{testimonial.persona}}</b></p></div>
		</li>
		{% endfor %}
	</ul>
	<div class="btn-row-inline">
		<a class="btn primary" href="/about">More About Me<i class="ri-arrow-right-s-fill"></i></a>
		<a class="btn primary" href="/about/#testimonials">All Testimonials<i class="ri-arrow-right-s-fill"></i></a>
	</div>
</section>

